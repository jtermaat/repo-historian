# Required: GitHub personal access token
GITHUB_TOKEN=

# Provide the API key for whichever LLM provider you're using.
# Only one is needed, based on the model configured in config.py.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LangSmith tracing (optional — leave blank to disable)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=repo-historian
